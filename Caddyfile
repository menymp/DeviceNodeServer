{$CADDY_HOST} {
    # -------------------------
    # Backend proxy: /backend* (proxy real requests; handle OPTIONS preflight locally)
    # -------------------------
    handle_path /backend* {
        # Local matcher for OPTIONS only (scoped inside this handle_path)
        @isOptions method OPTIONS

        # If it's an OPTIONS preflight, respond here and do not proxy to PHP
        handle @isOptions {
            header Access-Control-Allow-Origin "{http.request.header.Origin}"
            header Access-Control-Allow-Credentials "true"
            header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
            header Access-Control-Allow-Headers "{http.request.header.Access-Control-Request-Headers}"
            header Vary "Origin"
            respond "" 204
        }

        # Non-OPTIONS requests: proxy to PHP
        reverse_proxy php-node-service:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }

        # CORS headers for actual responses
        header Access-Control-Allow-Origin "{http.request.header.Origin}"
        header Access-Control-Allow-Credentials "true"
        header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
        header Vary "Origin"
    }

    # -------------------------
    # WebSocket proxy: /socket* (preserves Upgrade)
    # -------------------------
    handle_path /socket* {
        reverse_proxy websocket-service:{$WEBSOCKET_PORT} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }

        header Access-Control-Allow-Origin "{http.request.header.Origin}"
        header Access-Control-Allow-Credentials "true"
        header Vary "Origin"
    }

    # -------------------------
    # Video feed proxy: /video*
    # -------------------------
    handle_path /video* {
        reverse_proxy video-composer-service:{$VIDEO_SEED_PORT} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }

        header Access-Control-Allow-Origin "{http.request.header.Origin}"
        header Access-Control-Allow-Credentials "true"
        header Vary "Origin"
    }

    # -------------------------
    # Health check
    # -------------------------
    handle_path /health {
        respond "ok" 200
    }

    # -------------------------
    # Static / React UI proxy (everything else)
    # -------------------------
    handle {
        reverse_proxy react-device-manager-ui:{$REACT_MANAGER_PORT} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }

        header Access-Control-Allow-Origin "{http.request.header.Origin}"
        header Access-Control-Allow-Credentials "true"
        header Vary "Origin"
    }
}


