# Caddyfile for single-origin proxying of React, PHP API, WebSocket and Video service
# Host / IP to serve (replace with your public domain in production)
{$CADDY_HOST} {
    # -------------------------
    # API proxy: /api/*
    # -------------------------
    handle_path /backend* {
        reverse_proxy php-node-service:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}

            # Add CORS response headers for API responses
            header_down Access-Control-Allow-Origin "{http.request.header.Origin}"
            header_down Access-Control-Allow-Credentials "true"
            header_down Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
            header_down Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
            header_down Vary "Origin"
        }
    }

    # -------------------------
    # WebSocket proxy: /socket* (preserves Upgrade)
    # -------------------------
    handle_path /socket* {
        reverse_proxy websocket-service:{$WEBSOCKET_PORT} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}

            # If WS handshake responses need CORS headers (usually not), set them here
            header_down Access-Control-Allow-Origin "{http.request.header.Origin}"
            header_down Access-Control-Allow-Credentials "true"
            header_down Vary "Origin"
        }
    }

    # -------------------------
    # Video feed proxy: /video
    # -------------------------
    handle_path /video* {
        reverse_proxy video-composer-service:{$VIDEO_SEED_PORT} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}

            header_down Access-Control-Allow-Origin "{http.request.header.Origin}"
            header_down Access-Control-Allow-Credentials "true"
            header_down Vary "Origin"
        }
    }

    # -------------------------
    # Static / React UI proxy (everything else)
    # -------------------------
    handle {
        reverse_proxy react-device-manager-ui:{$REACT_MANAGER_PORT} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}

            header_down Access-Control-Allow-Origin "{http.request.header.Origin}"
            header_down Access-Control-Allow-Credentials "true"
            header_down Vary "Origin"
        }
    }
}

