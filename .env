DB_USER=web_client
DB_NAME=mechlabenviroment

DEVICE_MAIN_SERVER_PATH=tcp://*:5554
DEVICE_MAIN_LOCAL_CONN=tcp://node-device-manager-service:5554
DEVICE_MANAGER_SERVER_PATH=tcp://*:5555
DEVICE_MANAGER_LOCAL_CONN=tcp://device-manager-service:5555
VIDEO_HANDLER_SERVER_PATH=tcp://*:5556
VIDEO_HANDLER_LOCAL_CONN=tcp://video-composer-service:5556

ADD_DEVICES_TIME_POLL=10

SEARCH_DEVICES_PERIOD=20

WEBSOCKET_PORT=8112

VIDEO_SEED_PORT=9090


PHP_PORT=8080
PHP_OTA_PORT=10001

REACT_MANAGER_PORT=3000

XBEE_COORDINATOR_NAME=XbeeCoordinatorGate
XBEE_COORDINATOR_MANIFEST_PUBLISH_DELAY=6
XBEE_COORDINATOR_TTY_PORT=/dev/ttyUSB0
XBEE_COORDINATOR_BAUDRATE=9600

MQTT_BROKER_PORT=1883
DB_NODE_PORT=3306
MQTT_CLIENT_KEEPALIVE=60
# stop mysql.exe service to avoid conflicts with the db
#  use this to find if its still running netstat -ano | findstr :3307
#  tasklist /svc /FI "PID eq 4"                 to determine process using it